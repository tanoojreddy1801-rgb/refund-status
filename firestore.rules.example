rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /refundRecords/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /datasetMeta/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
